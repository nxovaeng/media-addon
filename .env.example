# Server port
PORT=3000

# TMDB API key for fetching movie/TV metadata
TMDB_API_KEY=your_tmdb_api_key_here

# Bangumi API URL for anime metadata
BANGUMI_API_URL=https://api.bgm.tv

# MediaFlow proxy URL for stream handling
MEDIAFLOW_PROXY_URL=http://your-mediaflow-proxy:8080

# Password for MediaFlow API
MEDIAFLOW_API_PASSWORD=your_mediaflow_password

# FebBox token for additional stream sources
FEBBOX_TOKEN=your_febbox_token_here

# Comma-separated list of access tokens for authentication (e.g., token1,token2)
ACCESS_TOKENS=your_access_tokens_here

# Comma-separated list of active aggregators (e.g., overseas-anime,domestic-donghua)
ACTIVE_AGGREGATORS=your_active_aggregators_here

# delpoy region 'all', 'mainland', 'overseas'
REGION=all

# Logging level (debug/info/warn/error)
LOG_LEVEL=info
